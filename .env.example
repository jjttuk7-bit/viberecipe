# =============================================================
# 바이브 레시피 환경 변수 (server-only)
# =============================================================
# 정책 (헌법 §8.5 + ADR D-011):
# - 이 파일에 있는 키는 모두 server-only. NEXT_PUBLIC_* 접두사 사용 금지.
# - NEXT_PUBLIC_* 접두사가 붙으면 Next.js가 클라이언트 번들에 포함시킨다.
#   ANTHROPIC_API_KEY / SUPABASE_SERVICE_ROLE_KEY / UPSTASH_REDIS_REST_TOKEN
#   는 클라이언트에 노출되면 사용자 한 명의 키로 전 세계가 비용을 태운다.
# - 실제 값은 .env.local 에만 둔다 (.gitignore 에 포함).
# - lib/env.ts 는 server-only 패키지로 import 그래프 강제 차단.
# =============================================================

# --- OpenAI (엔진) — 데모 모드 필수 ---
# /api/recipe BUILD 엔진. 이 키 하나만 있으면 데모가 동작한다.
# VIBE_RECIPE_MODEL 로 모델 교체 가능 (기본 gpt-4o-mini).
OPENAI_API_KEY=
VIBE_RECIPE_MODEL=gpt-4o

# --- Upstash Redis (Rate Limit, 선택) ---
# 설정 시 /api/* 에 IP 기반 rate limit 적용. **미설정이면 건너뜀**(데모 통과).
# 공개 URL 비용 보호가 필요하면 채운다.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Supabase (영속, 선택) — 현재 데모에서 미사용 ---
# 로그인/저장/Fingerprint 를 다시 켤 때만 필요 (Cook/Postmortem 복원 시).
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Rate Limit 파라미터 (선택, 미설정 시 lib/ratelimit.ts 기본값) ---
# 분당 요청 수 (sliding window). 빈 값이면 60.
# RATE_LIMIT_PER_MINUTE=60
